// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  uid                 Int       @id @default(autoincrement())
  email               String    @unique
  password            String?
  name                String
  phone               String    @default("")
  gender              String    @default("Not Specified")
  profilePhoto        String?
  isBlocked           Boolean   @default(false)
  onboardingCompleted Boolean   @default(false)
  authProvider        String    @default("email") // "email" | "google"
  googleId            String?
  fcmToken            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("users")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  emoji       String   @default("🐾")
  description String   @default("")
  colorHex    String   @default("0xFFF9EDE4")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model Listing {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String   @default("")
  price       Float    @default(0)
  categoryId  Int?
  breedId     Int?
  breedName   String   @default("")
  age         String   @default("")
  gender      String   @default("")
  location    String   @default("")
  images      Json     @default("[]")
  status      String   @default("active") // "active" | "sold" | "inactive"
  isFeatured  Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("listings")
}

model Chat {
  chatId          String   @id  // e.g. "1_2" (sorted user IDs joined by _)
  participants    Json     @default("[]")
  lastMessage     String   @default("")
  lastMessageTime DateTime?
  lastSenderId    Int?
  unreadCount     Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("chats")
}

model Message {
  id         Int      @id @default(autoincrement())
  chatId     String
  senderId   Int
  senderName String   @default("User")
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chatId])
  @@map("messages")
}

model Dog {
  dogId             Int      @id @default(autoincrement())
  userId            Int
  name              String
  breed             String   @default("")
  age               String   @default("")
  gender            String   @default("")
  weight            String   @default("")
  vaccinationStatus String   @default("")
  aggressiveLevel   String   @default("")
  photos            Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("dogs")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  listingId Int
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@map("favorites")
}

model Review {
  id           Int      @id @default(autoincrement())
  targetId     Int
  reviewerId   Int
  reviewerName String   @default("")
  rating       Float
  comment      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([targetId])
  @@map("reviews")
}

model SosAlert {
  id               Int      @id @default(autoincrement())
  userId           Int
  bookingId        Int?
  providerId       Int?
  emergencyContact String   @default("")
  status           String   @default("active") // "active" | "resolved"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("sos")
}

model ServiceProvider {
  userId       Int      @id
  name         String   @default("")
  bio          String   @default("")
  services     Json     @default("[]")
  location     String   @default("")
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  isVerified   Boolean  @default(false)
  profilePhoto String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("providers")
}

model ProviderAvailability {
  id             Int      @id @default(autoincrement())
  providerId     Int      @unique
  isAvailable    Boolean  @default(true)
  services       Json     @default("[]")
  pricing        Json     @default("{}")
  operatingHours Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("provider_availability")
}
