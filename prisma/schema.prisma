generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  uid                 Int      @id @default(autoincrement())
  email               String   @unique
  password            String?
  name                String
  phone               String   @default("")
  gender              String   @default("Not Specified")
  profilePhoto        String?
  isBlocked           Boolean  @default(false)
  onboardingCompleted Boolean  @default(false)
  authProvider        String   @default("email")
  googleId            String?
  fcmToken            String?
  freeListingsUsed    Int      @default(0)
  isPremium           Boolean  @default(false)
  subscriptionEnd     DateTime?
  subscriptionId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("users")
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  emoji       String   @default("🐾")
  description String   @default("")
  colorHex    String   @default("0xFFF9EDE4")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  imageUrl    String?

  @@map("categories")
}

model Listing {
  id                Int      @id @default(autoincrement())
  userId            Int
  title             String
  description       String   @default("")
  price             Float    @default(0)
  categoryId        Int?
  breedId           Int?
  breedName         String   @default("")
  age               String   @default("")
  gender            String   @default("")
  location          String   @default("")
  city              String   @default("")
  area              String   @default("")
  fullAddress       String   @default("")
  sellerPhone       String   @default("")
  isVaccinated      Boolean  @default(false)
  vetCertificateUrl String?
  images            Json     @default("[]")
  status            String   @default("active")
  isFeatured        Boolean  @default(false)
  views             Int      @default(0)
  weight            String   @default("")
  color             String   @default("")
  type              String   @default("sale")
  latitude          Float?
  longitude         Float?
  featuredUntil     DateTime?
  approvedAt        DateTime?
  puppyCount        Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("listings")
}

model Chat {
  chatId          String    @id
  participants    Json      @default("[]")
  lastMessage     String    @default("")
  lastMessageTime DateTime?
  lastSenderId    Int?
  unreadCount     Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("chats")
}

model Message {
  id         Int      @id @default(autoincrement())
  chatId     String
  senderId   Int
  senderName String   @default("User")
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chatId])
  @@map("messages")
}

model Dog {
  dogId             Int      @id @default(autoincrement())
  userId            Int
  name              String
  breed             String   @default("")
  age               String   @default("")
  gender            String   @default("")
  weight            String   @default("")
  vaccinationStatus String   @default("")
  aggressiveLevel   String   @default("")
  photos            Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("dogs")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  listingId Int
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@map("favorites")
}

model Review {
  id           Int      @id @default(autoincrement())
  targetId     Int
  reviewerId   Int
  reviewerName String   @default("")
  rating       Float
  comment      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([targetId])
  @@map("reviews")
}

model SosAlert {
  id               Int      @id @default(autoincrement())
  userId           Int
  bookingId        Int?
  providerId       Int?
  emergencyContact String   @default("")
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("sos")
}

model ServiceProvider {
  userId       Int      @id
  name         String   @default("")
  bio          String   @default("")
  services     Json     @default("[]")
  location     String   @default("")
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  isVerified      Boolean  @default(false)
  profilePhoto    String?
  aadhaarUrl      String?
  panCardUrl      String?
  operatingRadius Int      @default(10)
  availableSlots  Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("providers")
}

model ProviderAvailability {
  id             Int      @id @default(autoincrement())
  providerId     Int      @unique
  isAvailable    Boolean  @default(true)
  services       Json     @default("[]")
  pricing        Json     @default("{}")
  operatingHours Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("provider_availability")
}

model Booking {
  id          Int      @id @default(autoincrement())
  userId      Int
  listingId   Int?
  providerId  Int?
  sessionType String?
  amountPaid  Float    @default(0)
  status      String   @default("pending")
  date        String?
  timeSlot    String?
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bookings")
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  planName  String   @default("Premium")
  amount    Float    @default(0)
  status    String   @default("active")
  startDate DateTime @default(now())
  endDate   DateTime
  razorpayPaymentId String?
  razorpayOrderId   String?
  createdAt DateTime @default(now())

  @@map("subscriptions")
}

model Breed {
  id          Int      @id @default(autoincrement())
  name        String
  size        String   @default("Medium")
  categoryId  Int
  avgPriceMin Float    @default(0)
  avgPriceMax Float    @default(0)
  temperament String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("breeds")
}

model Banner {
  id          Int      @id @default(autoincrement())
  title       String   @default("")
  description String   @default("")
  imageUrl    String
  linkUrl     String?
  isActive    Boolean  @default(true)
  tag         String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?     // null if for admin
  target    String   @default("user") // 'user' or 'admin'
  title     String
  body      String
  data      Json     @default("{}")
  isRead    Boolean  @default(false)
  type      String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("notifications")
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// --- NEW MODELS FOR PRODUCTS & SERVICES ---

model ProductCategory {
  id        Int                  @id @default(autoincrement())
  name      String
  emoji     String               @default("🛍️")
  order     Int                  @default(0)
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  subs      ProductSubCategory[]
  products  Product[]

  @@map("product_categories")
}

model ProductSubCategory {
  id        Int             @id @default(autoincrement())
  catId     Int
  name      String
  order     Int             @default(0)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  category  ProductCategory @relation(fields: [catId], references: [id])
  products  Product[]

  @@map("product_subcategories")
}

model Product {
  id                Int                @id @default(autoincrement())
  sellerId          Int
  catId             Int
  subCatId          Int?
  name              String
  brand             String?
  suitableFor       Json               @default("[]") // [dogs, cats, etc]
  petSize           Json               @default("[]") // [small, medium, etc]
  ageGroup          Json               @default("[]") // [puppy, adult, etc]
  description       String             @default("")
  keyFeatures       Json               @default("[]")
  hasVariants       Boolean            @default(false)
  mrp               Float?
  sellingPrice      Float?
  stock             Int?
  images            Json               @default("[]")
  deliveryOptions   Json               @default("[]")
  deliveryCharge    Float              @default(0)
  deliveryType      String             @default("fixed") // free, fixed, above_x
  deliveryFreeAbove Float?
  deliveryDays      String?
  returnPolicy      String             @default("none")
  status            String             @default("pending")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          ProductCategory    @relation(fields: [catId], references: [id])
  subcategory       ProductSubCategory? @relation(fields: [subCatId], references: [id])
  variants          ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String   // e.g. "4kg", "Blue"
  mrp       Float
  price     Float
  stock     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@map("product_variants")
}

model ServiceCategory {
  id                Int      @id @default(autoincrement())
  name              String
  emoji             String   @default("✂️")
  description       String?
  commissionPercent Float    @default(0)
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("service_categories")
}
